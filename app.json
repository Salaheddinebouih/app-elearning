{
  "expo": {
    "name": "Haarlos",
    "slug": "almand-app",
    "icon": "./assets/alamd.jpeg",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "sdkVersion": "54.0.0",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Haarlos utilise le micro pour évaluer votre prononciation.",
        "NSSpeechRecognitionUsageDescription": "Haarlos utilise la reconnaissance vocale pour corriger votre lecture."
      },
      "bundleIdentifier": "com.almandapp"
    },
    "android": {
      "package": "com.almandapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/alamd.jpeg",
        "backgroundColor": "#ffffff"
      }
    },
    "splash": {
      "image": "./assets/alamd.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/notification.mp3"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow access to scan QR codes and barcodes"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Haarlos utilise le micro pour la pratique de lecture vocale."
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Haarlos utilise le micro pour évaluer votre prononciation.",
          "speechRecognitionPermission": "Haarlos utilise la reconnaissance vocale pour corriger votre lecture."
        }
      ],
      "./plugins/withAndroidXManifestFix.js"
    ],
    "extra": {
      "eas": {
        "projectId": "205bd1a9-e4b6-4084-a4f2-489b85fc89a2"
      }
    },
    "owner": "admin132435466565"
  }
}
